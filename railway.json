{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd server && node server-real.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 3000,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "volumes": [
      {
        "name": "asra-data",
        "mountPath": "/app/data"
      }
    ]
  }
}
