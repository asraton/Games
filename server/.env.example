# =============================================================================
# ASRA Coin Game - Environment Configuration
# =============================================================================
# BU KONFIGURATSIYA XAVFSIZLIGI UCHUN MUHIM:
# - HECH QACHON haqiqiy tokenlarni kodga yozmang!
# - Railway Environment Variables dan foydalaning
# - .env faylini .gitignore ga qo'shing
# =============================================================================

# Telegram Bot Configuration
# @BotFather dan olingan token
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# =============================================================================
# URLs Configuration
# =============================================================================
GAME_URL=https://your-app.up.railway.app
API_BASE_URL=https://your-app.up.railway.app/api
WEBHOOK_URL=https://your-app.up.railway.app/bot-webhook

# =============================================================================
# Database Configuration
# =============================================================================
# Railway Volume uchun data papkasi (persistent storage)
DATA_PATH=/data

# MongoDB (ixtiyoriy - hozircha JSON DB ishlatiladi)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tongame

# =============================================================================
# TON Blockchain Configuration
# =============================================================================
# TON Center API Key (toncenter.com dan olingan)
TON_API_KEY=your_ton_api_key_here

# To'lov manzili - foydalanuvchilar 1 TON yuboradigan manzil
# ⚠️ BU MANZILGA KELGAN TONLARGA EHTIYOT BO'LING!
PAYMENT_ADDRESS=your_ton_wallet_address_here


# =============================================================================
# Security Configuration
# =============================================================================
# Wallet mnemonics shifrlash uchun kalit (32+ belgi)
# AGAR BU O'RNATILMASA, mnemonics plain text saqlanadi!
# Masalan: WALLET_ENCRYPTION_KEY=MySuperSecretKey32CharsOrMore!!
WALLET_ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3000
NODE_ENV=production

# Webhook sozlamalari
USE_WEBHOOK=true

# =============================================================================
# Debug Configuration (FAQAT development rejimida)
# =============================================================================
# NODE_ENV=development bo'lsa, debug endpointlari ishlaydi
# NODE_ENV=production bo'lsa, debug endpointlari yopiq
