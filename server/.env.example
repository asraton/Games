# Telegram Bot Configuration
# @BotFather dan olingan tokenni shu yerga yozing
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Game URLs (Railway deployment URL)
GAME_URL=https://your-railway-url.railway.app
API_BASE_URL=https://your-railway-url.railway.app/api
BOT_USERNAME=your_bot_username

# TON API (toncenter.com dan olingan API key)
TON_API_KEY=your_ton_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB (agar ishlatilsa, aks holda in-memory ishlatiladi)
# MONGODB_URI=mongodb://localhost:27017/tongame
