# Telegram Bot Configuration
# @BotFather dan olingan tokenni shu yerga yozing (HECH QACHON kodga yozmang!)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# URLs - Railway (backend + frontend birga)
GAME_URL=https://asracoin.up.railway.app
API_BASE_URL=https://asracoin.up.railway.app/api
# Eski: API_BASE_URL=${GAME_URL}/api

# MongoDB Atlas (Cloud Database)
# MongoDB Atlas dan olingan connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tongame

# TON API (toncenter.com dan olingan API key)
TON_API_KEY=your_ton_api_key_here

# Payment Address - 1 TON to'lov qilish uchun manzil
# ⚠️ HECH QACHON kodga hardcoded qilmang!
# Railway Variables ga qo'shing: PAYMENT_ADDRESS=your_address_here
PAYMENT_ADDRESS=YOUR_TON_WALLET_ADDRESS_HERE

# Server Configuration
PORT=3000
NODE_ENV=production

# Webhook (Railway uchun USE_WEBHOOK=true)
USE_WEBHOOK=true
WEBHOOK_URL=https://asracoin.up.railway.app/bot-webhook
