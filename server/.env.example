# ASRA Coin Game - Environment Variables
# ========================================

# Telegram Bot Token (@BotFather dan oling)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# TON Center API Key (toncenter.com dan oling)
TON_API_KEY=your_ton_api_key_here

# To'lov manzili (1 TON qabul qiluvchi)
PAYMENT_ADDRESS=UQCtlk8bgwbSOt8OFnVe4KuFdQDo7kCbrZEhAOW1UUgUtIVM

# Master Wallet (TON yechib olish uchun)
MASTER_WALLET_MNEMONIC=your_24_word_mnemonic_here
MASTER_WALLET_ADDRESS=your_master_wallet_address_here

# Shifrlash kaliti (32+ belgi)
WALLET_ENCRYPTION_KEY=your_secret_key_32_chars_minimum

# URL manzillar
GAME_URL=https://your-app.up.railway.app
WEBHOOK_URL=https://your-app.up.railway.app/bot-webhook

# Server sozlamalari
PORT=3000
NODE_ENV=production
DATA_PATH=/data
USE_WEBHOOK=true
